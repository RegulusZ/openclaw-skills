#!/bin/bash
# Pull remote changes, handle conflicts

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SYNC_REPO="${SYNC_REPO:-$HOME/openclaw-sync}"
CONFIG_FILE="$HOME/.config/openclaw/sync-config.yaml"
FEISHU_NOTIFY="${FEISHU_NOTIFY:-true}"

cd "$SYNC_REPO"

# Check if git repo
if [[ ! -d ".git" ]]; then
    echo "Error: Not a git repository. Run sync-init first."
    exit 1
fi

# Fetch remote changes
git fetch origin

# Check if there are remote changes
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/HEAD 2>/dev/null || echo "$LOCAL")

if [[ "$LOCAL" == "$REMOTE" ]]; then
    # No changes to pull
    exit 0
fi

# Try to pull (rebase)
if git pull --rebase origin HEAD 2>/dev/null; then
    echo "✓ Pulled remote changes at $(date '+%H:%M:%S')"
    exit 0
fi

# Conflict detected
echo "⚠ CONFLICT DETECTED"

# Get conflicted files
CONFLICTS=$(git diff --name-only --diff-filter=U)

# Send notification via Feishu if available
if [[ "$FEISHU_NOTIFY" == "true" ]] && command -v openclaw &> /dev/null; then
    HOSTNAME=$(hostname)
    MSG="🚨 Sync Conflict on ${HOSTNAME}

Conflicting files:
${CONFLICTS}

Run to resolve:
  sync-resolve

Auto-sync paused until resolved."
    
    # Use openclaw to send message if in agent context
    # This requires OpenClaw to be running
    echo "$MSG" | tee -a "$SYNC_REPO/.sync-conflict.log"
fi

# Mark conflict state
echo "$(date): CONFLICT - $CONFLICTS" >> "$SYNC_REPO/.sync-conflict.log"
echo "$CONFLICTS" > "$SYNC_REPO/.sync-conflicts"

exit 1
